{
  "name": "@handled-ai/design-system",
  "version": "0.1.0",
  "description": "Handled UI component library (shadcn-style, New York)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/HandledAI/design-system"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system",
    "shadcn",
    "tailwind",
    "radix"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:lib": "tsup",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "registry:build": "shadcn build",
    "prepublishOnly": "npm run build:lib"
  },
  "peerDependencies": {
    "@radix-ui/react-label": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "date-fns": "^3.0.0 || ^4.0.0",
    "lucide-react": "^0.487.0",
    "radix-ui": "^1.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "recharts": "^2.0.0 || ^3.0.0",
    "@nivo/sankey": ">=0.80.0",
    "@nivo/core": ">=0.80.0",
    "tailwind-merge": "^2.0.0 || ^3.0.0",
    "zod": "^3.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/node": "^20.19.9",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "eslint": "^9.32.0",
    "eslint-config-next": "15.3.1",
    "next": "15.5.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "shadcn": "^3.0.0",
    "tailwindcss": "^4.1.11",
    "tsup": "^8.3.5",
    "tw-animate-css": "^1.3.6",
    "typescript": "^5.9.2"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.1.2",
      "@types/react-dom": "19.1.2"
    },
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "msw",
      "sharp",
      "unrs-resolver"
    ]
  }
